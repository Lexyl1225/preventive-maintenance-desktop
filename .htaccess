RewriteEngine On

# ── Skip API and script endpoints (keep .php extension for AJAX calls) ──
RewriteRule ^api/ - [L]
RewriteRule ^scripts/ - [L]

# ── External redirects: strip .php from browser URL bar ──

# /index.php  →  /
RewriteCond %{THE_REQUEST} \s/index\.php[?\s] [NC]
RewriteRule ^index\.php$ / [R=301,L,QSA]

# /page.php  →  /page
RewriteCond %{THE_REQUEST} \s/([^/\s]+)\.php[?\s] [NC]
RewriteRule ^([^/]+)\.php$ /$1 [R=301,L,QSA]

# ── Internal rewrite: serve the .php file behind the clean URL ──
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^/]+)$ $1.php [L,QSA]
